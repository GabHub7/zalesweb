# Neon Postgres connection strings.
# In Neon's dashboard, copy the "Pooled connection" string for DATABASE_URL
# and the "Direct connection" string for DIRECT_URL (used for migrations).
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/zales?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/zales?sslmode=require"

# ── Login (Auth.js / NextAuth) ────────────────────────────────────────
# Random secret used to sign session tokens. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET="ganti-dengan-random-string-panjang"

# Google sign-in (optional — email/password login works without this).
# Get these from https://console.cloud.google.com/apis/credentials
# → Create Credentials → OAuth client ID → Web application
# → Authorized redirect URI: https://<domain-kamu>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Used to verify the /api/webhooks/meta endpoint when you register it in the
# Meta App dashboard (Messenger/Instagram > Webhooks). Make up any random
# string, put the SAME string in Meta's "Verify token" field.
WEBHOOK_VERIFY_TOKEN="pilih-string-acak-sendiri"

# Secures /api/cron/tick so random people on the internet can't trigger your
# workflows. On Vercel this is auto-injected when you use vercel.json's
# `crons` config — you don't need to set it yourself there. Only set this
# manually if you're calling /api/cron/tick from an external cron service
# (see DEPLOY.md), and make that service send the same value as a
# `Authorization: Bearer <value>` header.
CRON_SECRET="pilih-string-acak-lain"

# ── Account Settings / API Key encryption (wajib) ──────────────────────
# Kunci rahasia server buat enkripsi AES-256-GCM API key yang disimpan user
# (Gemini/OpenAI/custom key) sebelum masuk database. Generate dengan:
#   openssl rand -base64 32
# JANGAN pakai default/contoh ini di production — kalau di-skip, key kamu
# masih akan tersimpan terenkripsi, tapi pakai kunci fallback yang sama di
# semua deployment tanpa env ini (tidak aman).
API_KEY_SECRET="ganti-dengan-random-string-panjang-lain"

# ── Forgot Password email (opsional) ───────────────────────────────────
# Kalau tidak diisi, link reset password tetap dibuat & disimpan di
# database, tapi cuma di-log ke server console (tidak ada email terkirim) —
# berguna untuk dev lokal. Isi ini untuk mengaktifkan pengiriman email asli
# lewat Resend (https://resend.com).
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
